---
// Cart sidebar — fully client-side, reads from nanostores
---
<aside class="cart-sidebar" id="cart-sidebar" aria-hidden="true" aria-label="Ostukorv">
  <div class="cart-sidebar__overlay" id="cart-overlay"></div>
  <div class="cart-sidebar__panel" role="dialog" aria-modal="true" aria-label="Ostukorv">

    <div class="cart-sidebar__header">
      <div>
        <h3>Ostukorv</h3>
        <span class="cart-item-count eyebrow" id="cart-item-count"></span>
      </div>
      <button class="cart-sidebar__close" id="cart-close-btn" aria-label="Sulge ostukorv">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="cart-sidebar__items" id="cart-items-list">
      <p class="cart-empty">Ostukorv on tühi</p>
    </div>

    <div class="cart-sidebar__footer" id="cart-footer">
      <div class="cart-total">
        <span>Kokku</span>
        <span id="cart-total-display">0,00&nbsp;€</span>
      </div>
      <p class="cart-shipping-note">Tasuta kohaletoimetamine üle 50&nbsp;€</p>
      <a class="btn btn--primary" id="checkout-btn" href="#">
        Mine kassasse
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <button class="btn btn--ghost" id="continue-shopping-btn">
        Jätka ostlemist
      </button>
    </div>

  </div>
</aside>

<script>
  import { gsap } from 'gsap';
  import { cartItems, cartOpen, cartTotal, cartCount, cartToken } from '../lib/stores';
  import { updateCartItem, removeCartItem, getCheckoutUrl } from '../lib/cart';

  const WC_URL = import.meta.env.PUBLIC_WC_URL;
  const sidebar = document.getElementById('cart-sidebar')!;
  const panel = sidebar.querySelector('.cart-sidebar__panel')!;
  const itemsList = document.getElementById('cart-items-list')!;
  const totalDisplay = document.getElementById('cart-total-display')!;
  const itemCountEl = document.getElementById('cart-item-count')!;
  const checkoutBtn = document.getElementById('checkout-btn') as HTMLAnchorElement;

  // Open/close state
  cartOpen.subscribe((open) => {
    sidebar.setAttribute('aria-hidden', String(!open));
    sidebar.classList.toggle('is-open', open);
    document.body.classList.toggle('cart-open', open);
  });

  const closeCart = () => cartOpen.set(false);

  document.getElementById('cart-close-btn')!.addEventListener('click', closeCart);
  document.getElementById('cart-overlay')!.addEventListener('click', closeCart);
  document.getElementById('continue-shopping-btn')!.addEventListener('click', closeCart);

  // Keyboard close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && cartOpen.get()) closeCart();
  });

  // Render cart items
  cartItems.subscribe((items) => {
    const count = items.reduce((sum, i) => sum + i.quantity, 0);
    itemCountEl.textContent = count > 0 ? `${count} toode${count !== 1 ? 't' : ''}` : '';

    if (items.length === 0) {
      itemsList.innerHTML = '<p class="cart-empty">Ostukorv on tühi</p>';
      return;
    }

    itemsList.innerHTML = items.map((item) => {
      const itemPrice = (parseInt(item.price) / 100).toFixed(2).replace('.', ',');
      return `
        <div class="cart-item" data-key="${item.key}">
          ${item.image ? `<img src="${item.image}" alt="${item.name}" class="cart-item__img" />` : '<div class="cart-item__img-placeholder"></div>'}
          <div class="cart-item__info">
            <p class="cart-item__name">${item.name}</p>
            <p class="cart-item__price">${itemPrice}&nbsp;€</p>
            <div class="cart-item__controls">
              <button class="cart-qty-btn" data-key="${item.key}" data-action="decrease" aria-label="Vähenda">−</button>
              <span class="cart-qty-value">${item.quantity}</span>
              <button class="cart-qty-btn" data-key="${item.key}" data-action="increase" aria-label="Suurenda">+</button>
              <button class="cart-remove-btn" data-key="${item.key}" aria-label="Eemalda">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      `;
    }).join('');

    // Re-attach events after render
    itemsList.querySelectorAll('.cart-qty-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const key = btn.getAttribute('data-key')!;
        const action = btn.getAttribute('data-action')!;
        const item = cartItems.get().find((i) => i.key === key);
        if (!item) return;
        const newQty = action === 'increase' ? item.quantity + 1 : item.quantity - 1;
        btn.closest('.cart-item')?.classList.add('cart-item--loading');
        await updateCartItem(key, newQty);
      });
    });

    itemsList.querySelectorAll('.cart-remove-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const key = btn.getAttribute('data-key')!;
        btn.closest('.cart-item')?.classList.add('cart-item--removing');
        await removeCartItem(key);
      });
    });
  });

  // Total
  cartTotal.subscribe((total) => {
    const formatted = (parseInt(total) / 100).toFixed(2).replace('.', ',');
    totalDisplay.textContent = `${formatted}\u00a0€`;
  });

  // Checkout URL
  cartToken.subscribe(() => {
    checkoutBtn.href = getCheckoutUrl();
  });
</script>

<style lang="scss">
  .cart-item-count {
    display: block;
    margin-top: 0.15rem;
    color: var(--muted);
  }

  .cart-shipping-note {
    font-size: 0.7rem;
    color: var(--muted);
    text-align: center;
    letter-spacing: 0.02em;
  }

  .cart-item {
    &__img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      flex-shrink: 0;
      background: var(--gray);
    }

    &__img-placeholder {
      width: 80px;
      height: 80px;
      background: var(--gray);
      flex-shrink: 0;
    }

    &--loading {
      opacity: 0.6;
      pointer-events: none;
    }

    &--removing {
      opacity: 0.4;
      pointer-events: none;
      transition: opacity 0.3s;
    }
  }
</style>
