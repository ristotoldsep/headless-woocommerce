---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <p class="footer__logo">Serum Shop</p>
        <p class="footer__tagline">Pikemad ripsmed, loomulikult.</p>
        <div class="footer__social">
          <a href="#" aria-label="Instagram" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="TikTok" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h4 class="footer__col-title">Toode</h4>
          <a href="#product">Koostisosad</a>
          <a href="#how-to-use">Kasutamine</a>
          <a href="#">KKK</a>
        </div>
        <div class="footer__col">
          <h4 class="footer__col-title">Info</h4>
          <a href="#">Privaatsuspoliitika</a>
          <a href="#">Tagastuspoliitika</a>
          <a href="#">Kontakt</a>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Serum Shop. Kõik õigused kaitstud.</p>
      <p class="footer__made-with">Valmistatud Eestis</p>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background: var(--black);
    color: rgba(255,255,255,0.6);
    padding: 4rem 0 2rem;

    &__top {
      display: flex;
      justify-content: space-between;
      gap: 3rem;
      margin-bottom: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);

      @media (max-width: 640px) {
        flex-direction: column;
        gap: 2rem;
      }
    }

    &__brand {
      max-width: 220px;
    }

    &__logo {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    &__tagline {
      font-size: 0.8rem;
      font-style: italic;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    &__social {
      display: flex;
      gap: 1rem;
    }

    &__links {
      display: flex;
      gap: 4rem;

      @media (max-width: 480px) {
        gap: 2rem;
      }
    }

    &__col {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;

      a {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.45);
        transition: color 0.2s;

        &:hover {
          color: var(--gold);
        }
      }
    }

    &__col-title {
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      margin-bottom: 0.25rem;
    }

    &__bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;

      p {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.25);
      }
    }

    &__made-with {
      font-family: var(--font-serif);
      font-style: italic;
    }
  }

  .social-link {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;

    &:hover {
      color: var(--gold);
    }
  }
</style>
