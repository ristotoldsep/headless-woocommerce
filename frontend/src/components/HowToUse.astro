---
const steps = [
  {
    number: '01',
    title: 'Puhasta',
    description: 'Puhasta ripsmed ja kulmud hoolikalt meigist ja mustusest. Nahk peab olema kuiv enne kandmist.',
  },
  {
    number: '02',
    title: 'Kanna',
    description: 'Kanna väike kogus seruumi õhukese pintslitükiga ripsme- ja kulmujuurele. Piisab ühest triibust.',
  },
  {
    number: '03',
    title: 'Lase imenduda',
    description: 'Lase serum imenduda üleöö. Ärge loputage. Kasutage iga õhtu regulaarsuse tagamiseks.',
  },
];
---
<section class="how-to-use" id="how-to-use">
  <div class="how-to-use__inner">

    <div class="how-to-use__header">
      <p class="eyebrow how-to-use__eyebrow">Kasutamisjuhend</p>
      <h2 class="how-to-use__title">Kuidas kasutada?</h2>
    </div>

    <div class="steps">
      {steps.map((step) => (
        <div class="step">
          <span class="step__ghost" aria-hidden="true">{step.number}</span>
          <div class="step__content">
            <span class="step__label">{step.number}</span>
            <h3 class="step__title">{step.title}</h3>
            <p class="step__desc">{step.description}</p>
          </div>
          <div class="step__dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
        </div>
      ))}
    </div>

    <div class="how-to-use__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>Optimaalsete tulemuste saavutamiseks kasutage vähemalt 8 järjestikusel nädalal</p>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.how-to-use__header > *', {
    y: 24, opacity: 0, stagger: 0.1, duration: 0.8, ease: 'power2.out',
    scrollTrigger: { trigger: '.how-to-use__header', start: 'top 80%' },
  });

  gsap.from('.step', {
    y: 32, opacity: 0, stagger: 0.15, duration: 0.9, ease: 'power3.out',
    scrollTrigger: { trigger: '.steps', start: 'top 75%' },
  });

  gsap.from('.how-to-use__note', {
    y: 20, opacity: 0, duration: 0.7,
    scrollTrigger: { trigger: '.how-to-use__note', start: 'top 88%' },
  });
</script>

<style lang="scss">
  .how-to-use {
    background: var(--white);
    padding: 6rem 2rem 7rem;
  }

  .how-to-use__inner {
    max-width: 700px;
    margin-left: 15%;

    @media (max-width: 1200px) {
      margin-left: 8%;
    }

    @media (max-width: 768px) {
      margin-left: 0;
      margin: 0 auto;
    }
  }

  .how-to-use__header {
    margin-bottom: 4rem;
  }

  .how-to-use__eyebrow {
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .how-to-use__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--black);
  }

  .how-to-use__note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    background: rgba(201, 169, 110, 0.07);
    border-left: 2px solid var(--gold);

    svg {
      color: var(--gold);
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    p {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.7;
    }
  }

  // ── Steps ────────────────────────────────────────────────────────────────────

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 2.5rem 0;
    position: relative;

    &:not(:last-child) {
      border-bottom: 1px solid var(--gray-dark);
    }

    // Large ghost number, layered behind content
    &__ghost {
      position: absolute;
      left: -0.5rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--font-serif);
      font-size: 6rem;
      font-weight: 300;
      line-height: 1;
      color: var(--black);
      opacity: 0.05;
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.02em;

      @media (max-width: 640px) {
        font-size: 4rem;
      }
    }

    &__content {
      flex: 1;
      position: relative;
      z-index: 1;
      padding-left: 3.5rem;

      @media (max-width: 640px) {
        padding-left: 2.5rem;
      }
    }

    &__label {
      display: block;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.5rem;
    }

    &__title {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 300;
      margin-bottom: 0.6rem;
      color: var(--black);
    }

    &__desc {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.75;
    }

    // Dot separator between steps
    &__dots {
      display: none;
    }
  }
</style>
