---
const ingredients = [
  {
    name: 'Biotiinüpeptiid',
    benefit: 'Tugevdab juuksevart ja parandab karva elastsust',
    icon: 'leaf',
    num: '01',
  },
  {
    name: 'Kopepiid',
    benefit: 'Stimuleerib karvafolliiklite kasvu ja pikendab kasvufaasi',
    icon: 'sparkle',
    num: '02',
  },
  {
    name: 'Panteniool (B5)',
    benefit: 'Niisutab sügavuti ja kaitseb kahjustuste eest',
    icon: 'drop',
    num: '03',
  },
  {
    name: 'Hüaluroonhape',
    benefit: 'Täidab niiskust ja hoiab ripsmed paindlikuna',
    icon: 'water',
    num: '04',
  },
  {
    name: 'Arganiinipeptiid',
    benefit: 'Parandab juuksestruktuuri ja lisab läiget',
    icon: 'gem',
    num: '05',
  },
  {
    name: 'Biotiin',
    benefit: 'Toetab keratiinitootmist tugevamate ripsmete jaoks',
    icon: 'molecule',
    num: '06',
  },
];

const icons: Record<string, string> = {
  leaf: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>',
  sparkle: '<path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>',
  drop: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>',
  water: '<path d="M5 12c0 3.87 3.13 7 7 7s7-3.13 7-7c0-4.5-3.5-8.07-7-10.5C8.5 3.93 5 7.5 5 12z"/>',
  gem: '<polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/>',
  molecule: '<circle cx="12" cy="12" r="3"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><line x1="14" y1="10" x2="17.5" y2="7.5"/><line x1="10" y1="10" x2="6.5" y2="7.5"/><line x1="10" y1="14" x2="6.5" y2="16.5"/>',
};

const heroIngredient = ingredients[0];
const restIngredients = ingredients.slice(1);
---
<section class="ingredients" id="ingredients">

  <span class="ingredients__watermark" aria-hidden="true">08</span>

  <div class="ingredients__container">

    <div class="ingredients__header">
      <p class="eyebrow ingredients__eyebrow">Teaduspõhine koostis</p>
      <h2 class="ingredients__title">Peamised koostisosad</h2>
      <p class="ingredients__subtitle">
        Iga koostisosa on hoolikalt valitud ja teaduslikult tõestatud toimega
      </p>
    </div>

    <!-- Hero card — spans full row -->
    <div class="ingredient-hero">
      <span class="ingredient-hero__num" aria-hidden="true">{heroIngredient.num}</span>
      <div class="ingredient-hero__left">
        <div class="ingredient-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[heroIngredient.icon]} />
        </div>
        <h3 class="ingredient-hero__name">{heroIngredient.name}</h3>
      </div>
      <p class="ingredient-hero__benefit">{heroIngredient.benefit}</p>
    </div>

    <!-- Cards 2–6 -->
    <div class="ingredients__grid">
      {restIngredients.map((ingredient) => (
        <div class="ingredient-card">
          <div class="ingredient-card__top">
            <span class="ingredient-card__num">{ingredient.num}</span>
            <div class="ingredient-card__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[ingredient.icon]} />
            </div>
          </div>
          <h3 class="ingredient-card__name">{ingredient.name}</h3>
          <p class="ingredient-card__benefit">{ingredient.benefit}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.ingredients__header > *', {
    y: 30, opacity: 0, stagger: 0.1, duration: 0.8, ease: 'power2.out',
    scrollTrigger: { trigger: '.ingredients__header', start: 'top 80%' },
  });

  gsap.from('.ingredient-hero', {
    y: 40, opacity: 0, duration: 1.0, ease: 'power3.out',
    scrollTrigger: { trigger: '.ingredient-hero', start: 'top 80%' },
  });

  gsap.from('.ingredient-card', {
    y: 36, opacity: 0, stagger: 0.1, duration: 0.8, ease: 'power2.out',
    scrollTrigger: { trigger: '.ingredients__grid', start: 'top 80%' },
  });
</script>

<style lang="scss">
  .ingredients {
    background: var(--black);
    color: var(--white);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .ingredients__watermark {
    position: absolute;
    top: 50%;
    right: -2rem;
    transform: translateY(-50%);
    font-family: var(--font-serif);
    font-size: clamp(14rem, 22vw, 22rem);
    font-weight: 300;
    line-height: 1;
    color: var(--white);
    opacity: 0.03;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  .ingredients__container {
    padding: 0 4rem 0 6rem;
    max-width: 1400px;
    position: relative;
    z-index: 1;

    @media (max-width: 1024px) {
      padding: 0 3rem 0 3rem;
    }

    @media (max-width: 640px) {
      padding: 0 1.5rem;
    }
  }

  .ingredients__header {
    max-width: 560px;
    margin-bottom: 4rem;
  }

  .ingredients__eyebrow {
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .ingredients__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .ingredients__subtitle {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
  }

  // ── Hero card ────────────────────────────────────────────────────────────────

  .ingredient-hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 2.5rem 3rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 2px;
    position: relative;
    transition: border-color 0.3s;

    &:hover {
      border-color: rgba(201, 169, 110, 0.3);
    }

    @media (max-width: 640px) {
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 1.5rem;
    }

    &__num {
      position: absolute;
      top: 1rem;
      right: 1.5rem;
      font-family: var(--font-serif);
      font-size: 0.65rem;
      color: var(--gold);
      opacity: 0.5;
      letter-spacing: 0.1em;
    }

    &__left {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-shrink: 0;
      min-width: 260px;

      @media (max-width: 640px) {
        min-width: unset;
      }
    }

    &__icon {
      color: var(--gold);
    }

    &__name {
      font-family: var(--font-serif);
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 300;
      color: var(--white);
    }

    &__benefit {
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.55);
      line-height: 1.7;
      flex: 1;
    }
  }

  // ── Regular grid ─────────────────────────────────────────────────────────────

  .ingredients__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;

    @media (max-width: 480px) {
      grid-template-columns: 1fr;
    }
  }

  .ingredient-card {
    padding: 2rem 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.3s var(--ease-luxury), border-color 0.3s;

    &:hover {
      background: rgba(255, 255, 255, 0.03);
      border-color: rgba(201, 169, 110, 0.25);
    }

    &__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    &__num {
      font-family: var(--font-serif);
      font-size: 0.65rem;
      color: var(--gold);
      opacity: 0.5;
      letter-spacing: 0.1em;
    }

    &__icon {
      color: var(--gold);
      opacity: 0.85;
    }

    &__name {
      font-family: var(--font-serif);
      font-size: 1.05rem;
      font-weight: 300;
      color: var(--white);
      margin-bottom: 0.6rem;
    }

    &__benefit {
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.7;
    }
  }
</style>
