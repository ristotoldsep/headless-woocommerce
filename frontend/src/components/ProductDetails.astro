---
interface Props {
  product: {
    id: number;
    name: string;
    price: string;
    regular_price: string;
    sale_price: string;
    short_description: string;
    stock_status: string;
  };
}

const { product } = Astro.props;
const price = parseFloat(product.price).toFixed(2).replace('.', ',');
const isOnSale = product.sale_price && product.sale_price !== product.regular_price;
const regularPriceFormatted = parseFloat(product.regular_price).toFixed(2).replace('.', ',');
const inStock = product.stock_status === 'instock';
---
<section class="product-details section" id="product">
  <div class="container">
    <div class="product-details__inner">
      <div class="product-details__content">
        <p class="eyebrow">Multi-peptiid seerum</p>
        <div class="divider"></div>
        <h2 class="product-details__name">{product.name}</h2>

        <div class="product-details__price-row">
          <span class="product-details__price">{price}&nbsp;€</span>
          {isOnSale && (
            <span class="product-details__regular-price">{regularPriceFormatted}&nbsp;€</span>
          )}
          {inStock ? (
            <span class="product-details__stock in-stock">Laos olemas</span>
          ) : (
            <span class="product-details__stock out-of-stock">Laost otsas</span>
          )}
        </div>

        <div class="product-details__desc" set:html={product.short_description} />

        <div class="product-details__actions">
          <div class="qty-control" aria-label="Kogus">
            <button class="qty-dec" aria-label="Vähenda kogust">−</button>
            <input
              type="number"
              class="qty-input"
              value="1"
              min="1"
              max="99"
              aria-label="Kogus"
            />
            <button class="qty-inc" aria-label="Suurenda kogust">+</button>
          </div>

          <button
            class="btn btn--primary add-to-cart-btn"
            id="add-to-cart-btn"
            data-product-id={product.id}
            disabled={!inStock}
          >
            {inStock ? 'Lisa ostukorvi' : 'Laost otsas'}
          </button>
        </div>

        <div class="product-details__meta">
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Nahakaitstud koostis</span>
          </div>
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Tulemused 4 nädalaga</span>
          </div>
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span>Julm testitud</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { addToCart } from '../lib/cart';

  gsap.registerPlugin(ScrollTrigger);

  // Animate section on scroll
  gsap.from('.product-details__content > *', {
    y: 30,
    opacity: 0,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '.product-details',
      start: 'top 70%',
    },
  });

  // Quantity controls
  const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;
  const qtyInput = document.querySelector('.qty-input') as HTMLInputElement;
  const qtyDec = document.querySelector('.qty-dec') as HTMLButtonElement;
  const qtyInc = document.querySelector('.qty-inc') as HTMLButtonElement;

  qtyDec.addEventListener('click', () => {
    const val = parseInt(qtyInput.value);
    if (val > 1) qtyInput.value = String(val - 1);
  });

  qtyInc.addEventListener('click', () => {
    const val = parseInt(qtyInput.value);
    if (val < 99) qtyInput.value = String(val + 1);
  });

  qtyInput.addEventListener('change', () => {
    const val = parseInt(qtyInput.value);
    if (isNaN(val) || val < 1) qtyInput.value = '1';
    if (val > 99) qtyInput.value = '99';
  });

  // Add to cart
  btn?.addEventListener('click', async () => {
    const productId = parseInt(btn.dataset.productId!);
    const quantity = parseInt(qtyInput.value) || 1;

    btn.disabled = true;
    btn.textContent = 'Lisatakse...';

    try {
      await addToCart(productId, quantity);
      btn.textContent = 'Lisatud! ✓';
      setTimeout(() => {
        btn.textContent = 'Lisa ostukorvi';
        btn.disabled = false;
      }, 2000);
    } catch (err) {
      console.error(err);
      btn.textContent = 'Viga — proovi uuesti';
      btn.disabled = false;
    }
  });
</script>

<style lang="scss">
  .product-details {
    background: var(--white);

    &__inner {
      max-width: 600px;
    }

    &__name {
      font-size: clamp(1.75rem, 3vw, 2.75rem);
      font-weight: 300;
      margin-bottom: 1.5rem;
      line-height: 1.1;
    }

    &__price-row {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }

    &__price {
      font-family: var(--font-serif);
      font-size: 2rem;
      font-weight: 300;
      color: var(--black);
    }

    &__regular-price {
      font-size: 1.1rem;
      color: var(--muted);
      text-decoration: line-through;
    }

    &__stock {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.75rem;
      border-radius: 999px;

      &.in-stock {
        background: #f0fdf4;
        color: #166534;
      }

      &.out-of-stock {
        background: #fef2f2;
        color: #991b1b;
      }
    }

    &__desc {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.8;
      margin-bottom: 2rem;

      :global(p) { margin-bottom: 0.5rem; }
    }

    &__actions {
      display: flex;
      align-items: stretch;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    &__meta {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;

    svg {
      color: var(--gold);
      flex-shrink: 0;
    }
  }
</style>
