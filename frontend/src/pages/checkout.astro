---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Checkout | Serum Shop" description="Esita tellimus">
  <div class="checkout-page">

    <!-- Header bar -->
    <header class="checkout-header">
      <a href="/" class="checkout-logo">Serum Shop</a>
      <div class="checkout-steps">
        <span class="step active">Tellimus</span>
        <span class="step-sep">→</span>
        <span class="step">Kinnitus</span>
      </div>
    </header>

    <main class="checkout-main">

      <!-- Left: order summary -->
      <aside class="order-summary" id="order-summary">
        <a href="/" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>
          Tagasi poodi
        </a>
        <h2 class="order-summary__title">Tellimuse kokkuvõte</h2>
        <div id="summary-items" class="summary-items">
          <p class="summary-empty">Ostukorv on tühi</p>
        </div>
        <div class="summary-totals" id="summary-totals" style="display:none">
          <div class="summary-row">
            <span>Vahesumma</span>
            <span id="summary-subtotal">—</span>
          </div>
          <div class="summary-row">
            <span>Transport</span>
            <span class="summary-free">Tasuta</span>
          </div>
          <div class="summary-row summary-row--total">
            <span>Kokku</span>
            <span id="summary-total">—</span>
          </div>
        </div>
      </aside>

      <!-- Right: checkout form -->
      <section class="checkout-form-wrap">
        <form id="checkout-form" class="checkout-form" novalidate>

          <!-- Contact -->
          <fieldset class="form-section">
            <legend class="form-section__title">
              <span class="form-section__num">01</span>
              Kontaktinfo
            </legend>
            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="first_name">Eesnimi *</label>
                <input type="text" id="first_name" name="first_name" autocomplete="given-name" required />
              </div>
              <div class="form-field">
                <label for="last_name">Perekonnanimi *</label>
                <input type="text" id="last_name" name="last_name" autocomplete="family-name" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="email">E-post *</label>
                <input type="email" id="email" name="email" autocomplete="email" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="phone">Telefon *</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+372" required />
              </div>
            </div>
          </fieldset>

          <!-- Shipping address -->
          <fieldset class="form-section">
            <legend class="form-section__title">
              <span class="form-section__num">02</span>
              Tarneaadress
            </legend>
            <div class="form-row">
              <div class="form-field">
                <label for="address_1">Tänav ja majanumber *</label>
                <input type="text" id="address_1" name="address_1" autocomplete="address-line1" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="address_2">Korter / lisa (valikuline)</label>
                <input type="text" id="address_2" name="address_2" autocomplete="address-line2" />
              </div>
            </div>
            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="city">Linn *</label>
                <input type="text" id="city" name="city" autocomplete="address-level2" required />
              </div>
              <div class="form-field">
                <label for="postcode">Sihtnumber *</label>
                <input type="text" id="postcode" name="postcode" autocomplete="postal-code" required />
              </div>
            </div>
            <input type="hidden" name="country" value="EE" />
          </fieldset>

          <!-- Notes -->
          <fieldset class="form-section">
            <legend class="form-section__title">
              <span class="form-section__num">03</span>
              Märkused (valikuline)
            </legend>
            <div class="form-row">
              <div class="form-field">
                <label for="customer_note">Lisainfo tellimusele</label>
                <textarea id="customer_note" name="customer_note" rows="3" placeholder="Nt. jäta ukse taha..."></textarea>
              </div>
            </div>
          </fieldset>

          <!-- Payment -->
          <fieldset class="form-section">
            <legend class="form-section__title">
              <span class="form-section__num">04</span>
              Makseviis
            </legend>
            <label class="payment-card payment-card--selected">
              <input type="radio" name="payment_method" value="bacs" checked hidden />
              <div class="payment-card__inner">
                <div class="payment-card__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                  </svg>
                </div>
                <div>
                  <p class="payment-card__name">Pangaülekanne</p>
                  <p class="payment-card__desc">Tee ülekanne meie kontole. Tellimus kinnitatakse makse laekumisel.</p>
                </div>
                <div class="payment-card__check">✓</div>
              </div>
              <div class="payment-card__details">
                <div class="bank-detail"><span>Saaja</span><strong>Serum Shop OÜ</strong></div>
                <div class="bank-detail"><span>IBAN</span><strong>EE12 3456 7890 1234 5678</strong></div>
                <div class="bank-detail"><span>SWIFT/BIC</span><strong>HABAEE2X</strong></div>
                <div class="bank-detail"><span>Selgitus</span><strong id="payment-ref">Tellimuse number (kuvatakse peale tellimuse esitamist)</strong></div>
              </div>
            </label>
          </fieldset>

          <!-- Error display -->
          <div class="form-error" id="form-error" style="display:none" role="alert"></div>

          <!-- Submit -->
          <button type="submit" class="btn btn--primary btn--submit" id="submit-btn">
            Esita tellimus
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>

          <p class="form-disclaimer">
            Tellimuse esitamisega nõustud meie <a href="#">privaatsuspoliitikaga</a>.
          </p>

        </form>
      </section>

    </main>
  </div>
</Layout>

<script>
  import { cartItems, cartTotal, cartCount } from '../lib/stores';
  import { placeOrder, fetchCart } from '../lib/cart';
  import type { CheckoutData } from '../lib/cart';

  // ── Render order summary ──────────────────────────────────────────────────
  const summaryItemsEl = document.getElementById('summary-items')!;
  const summaryTotalsEl = document.getElementById('summary-totals')!;
  const summarySubtotalEl = document.getElementById('summary-subtotal')!;
  const summaryTotalEl = document.getElementById('summary-total')!;

  // Show loading state while we re-hydrate the cart from the persisted Cart-Token
  summaryItemsEl.innerHTML = '<p class="summary-loading">Laen ostukorvi…</p>';
  let cartReady = false;

  // cartItems is a plain atom (resets on page load), so we must re-fetch
  // using the Cart-Token that was persisted in localStorage by the main page.
  fetchCart().catch(() => {}).finally(() => {
    cartReady = true;
    // If still empty after fetch, show the empty state
    if (cartItems.get().length === 0) {
      summaryItemsEl.innerHTML = '<p class="summary-empty">Ostukorv on tühi</p>';
      summaryTotalsEl.style.display = 'none';
    }
  });

  cartItems.subscribe((items) => {
    if (!cartReady && items.length === 0) return; // still loading, don't flash empty
    if (items.length === 0) {
      summaryItemsEl.innerHTML = '<p class="summary-empty">Ostukorv on tühi</p>';
      summaryTotalsEl.style.display = 'none';
      return;
    }
    summaryTotalsEl.style.display = 'block';
    summaryItemsEl.innerHTML = items.map((item) => {
      const price = (parseInt(item.price) / 100).toFixed(2).replace('.', ',');
      return `
        <div class="summary-item">
          ${item.image ? `<div class="summary-item__img-wrap"><img src="${item.image}" alt="${item.name}" /></div>` : ''}
          <div class="summary-item__info">
            <p class="summary-item__name">${item.name}</p>
            <p class="summary-item__qty">× ${item.quantity}</p>
          </div>
          <p class="summary-item__price">${price}&nbsp;€</p>
        </div>
      `;
    }).join('');
  });

  cartTotal.subscribe((total) => {
    const formatted = (parseInt(total) / 100).toFixed(2).replace('.', ',');
    summarySubtotalEl.textContent = `${formatted}\u00a0€`;
    summaryTotalEl.textContent = `${formatted}\u00a0€`;
  });

  // ── Form submission ───────────────────────────────────────────────────────
  const form = document.getElementById('checkout-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error')!;

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.style.display = 'block';
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    errorEl.style.display = 'none';
  }

  function getField(name: string): string {
    const el = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;
    return el?.value.trim() ?? '';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    if (cartCount.get() === 0) {
      showError('Ostukorv on tühi. Lisa toode enne tellimise jätkamist.');
      return;
    }

    // Client-side validation
    const required = ['first_name', 'last_name', 'email', 'phone', 'address_1', 'city', 'postcode'];
    for (const field of required) {
      if (!getField(field)) {
        const label = form.querySelector(`label[for="${field}"]`)?.textContent?.replace('*', '').trim() ?? field;
        showError(`Palun täida väli: ${label}`);
        (form.elements.namedItem(field) as HTMLElement)?.focus();
        return;
      }
    }

    const email = getField('email');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('Palun sisesta korrektne e-posti aadress.');
      return;
    }

    const data: CheckoutData = {
      billing_address: {
        first_name: getField('first_name'),
        last_name:  getField('last_name'),
        email:      getField('email'),
        phone:      getField('phone'),
        address_1:  getField('address_1'),
        address_2:  getField('address_2'),
        city:       getField('city'),
        postcode:   getField('postcode'),
        country:    'EE',
      },
      payment_method: 'bacs',
      customer_note:  getField('customer_note'),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Saadan tellimust...';

    try {
      const order = await placeOrder(data);
      window.location.href = `/order-confirmation?id=${order.order_id}&key=${order.order_key}&num=${order.order_number}`;
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Viga tellimuse esitamisel';
      showError(msg);
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Esita tellimus <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    }
  });
</script>

<style lang="scss">
  .checkout-page {
    min-height: 100vh;
    background: var(--white);
  }

  // ── Header ──────────────────────────────────────────────────────────────
  .checkout-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    border-bottom: 1px solid var(--gray-dark);
    position: sticky;
    top: 0;
    background: var(--white);
    z-index: 10;
  }

  .checkout-logo {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--black);
  }

  .checkout-steps {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .step {
    color: var(--muted);
    &.active { color: var(--black); font-weight: 500; }
  }

  .step-sep { color: var(--gray-dark); }

  // ── Main layout ──────────────────────────────────────────────────────────
  .checkout-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 4rem);

    @media (max-width: 900px) {
      grid-template-columns: 1fr;
    }
  }

  // ── Order summary (left) ─────────────────────────────────────────────────
  .order-summary {
    background: var(--gray);
    padding: 3rem 3rem 3rem 2.5rem;
    border-right: 1px solid var(--gray-dark);

    @media (max-width: 900px) {
      border-right: none;
      border-bottom: 1px solid var(--gray-dark);
      padding: 2rem 1.5rem;
    }

    &__title {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 300;
      letter-spacing: 0.05em;
      margin-bottom: 1.75rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--gray-dark);
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2rem;
    transition: color 0.2s;

    &:hover { color: var(--black); }
  }

  .summary-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .summary-empty {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
  }

  .summary-loading {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
    opacity: 0.6;
  }

  .summary-item {
    display: flex;
    align-items: center;
    gap: 1rem;

    &__img-wrap {
      width: 60px;
      height: 60px;
      flex-shrink: 0;
      background: var(--gray-dark);
      overflow: hidden;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    &__info {
      flex: 1;
    }

    &__name {
      font-size: 0.8rem;
      line-height: 1.4;
      color: var(--black);
    }

    &__qty {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    &__price {
      font-family: var(--font-serif);
      font-size: 1rem;
      font-weight: 300;
      white-space: nowrap;
    }
  }

  .summary-totals {
    border-top: 1px solid var(--gray-dark);
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--muted);

    &--total {
      color: var(--black);
      font-size: 0.9rem;
      padding-top: 0.5rem;
      margin-top: 0.25rem;
      border-top: 1px solid var(--gray-dark);

      span:last-child {
        font-family: var(--font-serif);
        font-size: 1.15rem;
        font-weight: 300;
      }
    }
  }

  .summary-free {
    color: #166534;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }

  // ── Checkout form (right) ────────────────────────────────────────────────
  .checkout-form-wrap {
    padding: 3rem 2.5rem 3rem 3rem;
    max-width: 560px;

    @media (max-width: 900px) {
      padding: 2rem 1.5rem;
      max-width: 100%;
    }
  }

  .checkout-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-section {
    border: none;
    padding: 0;
    margin: 0;

    &__title {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--black);
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--gray-dark);
      width: 100%;
    }

    &__num {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 300;
      color: var(--gold);
      letter-spacing: 0;
    }
  }

  .form-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;

    &--2 {
      @media (max-width: 480px) {
        flex-direction: column;
      }
    }
  }

  .form-field {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;

    label {
      font-size: 0.67rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }

    input, textarea {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--gray-dark);
      background: var(--white);
      font-family: var(--font-sans);
      font-size: 0.875rem;
      color: var(--black);
      outline: none;
      transition: border-color 0.2s;
      border-radius: 0;
      -webkit-appearance: none;

      &:focus {
        border-color: var(--black);
      }

      &::placeholder {
        color: rgba(107, 107, 107, 0.5);
      }
    }

    textarea {
      resize: vertical;
      min-height: 80px;
    }
  }

  // ── Payment card ─────────────────────────────────────────────────────────
  .payment-card {
    display: block;
    border: 1px solid var(--black);
    cursor: pointer;

    &--selected {
      border-color: var(--black);
    }

    &__inner {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
    }

    &__icon {
      color: var(--gold);
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    &__name {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--black);
      margin-bottom: 0.25rem;
    }

    &__desc {
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.5;
    }

    &__check {
      margin-left: auto;
      font-size: 0.8rem;
      color: var(--gold);
      flex-shrink: 0;
    }

    &__details {
      border-top: 1px solid var(--gray-dark);
      padding: 1rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      background: var(--gray);
    }
  }

  .bank-detail {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;

    span {
      color: var(--muted);
      min-width: 5rem;
      flex-shrink: 0;
    }

    strong {
      color: var(--black);
      font-weight: 500;
    }
  }

  // ── Error + submit ───────────────────────────────────────────────────────
  .form-error {
    padding: 0.875rem 1rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .btn--submit {
    width: 100%;
    padding: 1.1rem;
    font-size: 0.75rem;
    gap: 0.75rem;
  }

  .form-disclaimer {
    font-size: 0.7rem;
    color: var(--muted);
    text-align: center;
    line-height: 1.6;

    a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  }
</style>
