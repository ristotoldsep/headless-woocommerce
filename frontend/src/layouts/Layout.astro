---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Serum Shop — Ripsme- ja kulmude seerum',
  description = 'Professionaalne multi-peptiid seerum ripsmeile ja kulmudele. 8 bioaktiivset peptiidi täiustatud kasvuks ja tugevuseks.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
